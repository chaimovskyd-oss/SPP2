{
  "name": "spp-v2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SPP v2 architecture proof for a modular print-design Electron app",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "electron": "node scripts/run-electron.cjs",
    "build:print-hub-server": "node scripts/build-print-hub-server.cjs",
    "build:advanced-print-worker": "node scripts/build-advanced-print-worker.cjs",
    "print-hub-server": "node scripts/build-print-hub-server.cjs && electron electron/printHubServer.cjs",
    "fetch:python": "node scripts/fetch-python-embed.cjs",
    "pack": "vite build && npm run build:print-hub-server && npm run build:advanced-print-worker && electron-builder --dir",
    "dist": "vite build && npm run build:print-hub-server && npm run build:advanced-print-worker && electron-builder --win nsis",
    "dist:mac": "vite build && npm run build:print-hub-server && electron-builder --mac dmg",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.hadish.spp2",
    "productName": "SPP2",
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "spp2_advanced_print_worker/dist",
        "to": "spp2_advanced_print_worker",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "image.editor.engine",
        "to": "image.editor.engine",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!models/**",
          "!gfpgan/weights/**",
          "!smart_image_editor/models/**"
        ]
      },
      {
        "from": "print.preview.engine",
        "to": "print.preview.engine",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "product_library",
        "to": "product_library",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!exports/**",
          "!thumbnails/**"
        ]
      },
      {
        "from": "build/python-embed",
        "to": "python-embed"
      },
      {
        "from": "docs/guide-mapping",
        "to": "docs/guide-mapping"
      },
      {
        "from": "output/playwright/guide-mapping/screenshots",
        "to": "output/playwright/guide-mapping/screenshots"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "fileAssociations": [
      {
        "ext": "spp",
        "name": "SPP Project",
        "description": "SPP project file",
        "icon": "build/icon.ico",
        "role": "Editor"
      },
      {
        "ext": "spp2",
        "name": "SPP2 Project",
        "description": "קובץ פרויקט SPP2",
        "icon": "build/icon.ico",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "SPP2-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "SPP2",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.graphics-design"
    }
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^5.1.1",
    "busboy": "^1.6.0",
    "heic2any": "^0.0.4",
    "konva": "^10.0.12",
    "lucide-react": "^0.555.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.0.10",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/busboy": "^1.5.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "wait-on": "^9.0.10"
  }
}
